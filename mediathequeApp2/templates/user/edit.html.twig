{% extends 'base.html.twig' %}

{% block title %}Modifier un utilisateur{% endblock %}

{% block content %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7 col-md-9">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h1 class="h4 mb-3 text-center">
                        {{ is_own_profile ? 'Modifier mon profil' : 'Modifier un utilisateur' }}
                    </h1>
                    {% if not is_own_profile %}
                        <div class="alert alert-info py-2">
                            Le mot de passe de cet utilisateur ne peut pas être modifié ici.
                        </div>
                    {% endif %}
                    {{ include('user/_form.html.twig', {
                        button_label: 'Enregistrer',
                        back_path: is_own_profile ? path('app_profile') : path('app_user_show', {'idUtilisateur': utilisateur.idUtilisateur})
                    }) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
