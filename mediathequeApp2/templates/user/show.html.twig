{% extends 'base.html.twig' %}

{% block title %}Utilisateur{% endblock %}

{% block content %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h1 class="h4 mb-4">Mon profil</h1>
                    <table class="table">
                        <tbody>
                            <tr><th>ID</th><td>{{ utilisateur.idUtilisateur }}</td></tr>
                            <tr><th>Nom</th><td>{{ utilisateur.nom }}</td></tr>
                            <tr><th>Prénom</th><td>{{ utilisateur.prenom }}</td></tr>
                            <tr><th>Email</th><td>{{ utilisateur.email }}</td></tr>
                            <tr><th>Rôle</th><td>{{ utilisateur.idRole ? utilisateur.idRole.nomRole : 'user' }}</td></tr>
                        </tbody>
                    </table>

                    <div class="d-flex gap-2">
                        <a class="btn btn-outline-primary" href="{{ path('app_user_edit', {'idUtilisateur': utilisateur.idUtilisateur}) }}">Modifier</a>
                        <a class="btn btn-outline-secondary" href="{{ path('home') }}">Retour</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
