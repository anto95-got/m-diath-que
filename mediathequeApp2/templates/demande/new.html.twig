{% extends 'base.html.twig' %}

{% block title %}Proposition d'achat{% endblock %}

{% block content %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h1 class="h4 mb-2 text-center">Proposition d'achat</h1>
                    <p class="text-muted text-center small mb-4">Pour les livres absents du catalogue uniquement.</p>
                    {{ form_start(form) }}
                        <div class="form-floating mb-3">
                            {{ form_widget(form.titreDemande, {'attr': {'class': 'form-control', 'placeholder': 'Titre'}}) }}
                            <label for="{{ form.titreDemande.vars.id }}">Titre du livre</label>
                            {{ form_errors(form.titreDemande) }}
                        </div>
                        <div class="form-floating mb-3">
                            {{ form_widget(form.auteurDemande, {'attr': {'class': 'form-control', 'placeholder': 'Auteur'}}) }}
                            <label for="{{ form.auteurDemande.vars.id }}">Auteur</label>
                            {{ form_errors(form.auteurDemande) }}
                        </div>
                        <div class="form-floating mb-3">
                            {{ form_widget(form.quantiteDemandee, {'attr': {'class': 'form-control', 'placeholder': 'Nombre d\'exemplaires souhaités'}}) }}
                            <label for="{{ form.quantiteDemandee.vars.id }}">Nombre d'exemplaires souhaités</label>
                            {{ form_errors(form.quantiteDemandee) }}
                        </div>
                        <button class="btn btn-primary w-100" type="submit">Envoyer</button>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
