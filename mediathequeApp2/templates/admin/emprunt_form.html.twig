{% extends 'base.html.twig' %}

{% block title %}Nouvel emprunt{% endblock %}

{% block content %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7 col-md-9">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h1 class="h4 mb-4 text-center">Nouvel emprunt</h1>
                    {{ form_start(form) }}
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Utilisateur</label>
                            {{ form_widget(form.idUtilisateur, {'attr': {'class': 'form-select'}}) }}
                            {{ form_errors(form.idUtilisateur) }}
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Code-barres</label>
                            {{ form_widget(form.codeBarres, {'attr': {'class': 'form-control', 'placeholder': 'Scanner / saisir le code-barres'}}) }}
                            {{ form_errors(form.codeBarres) }}
                            <div id="doc-preview" class="small mt-2 text-muted"></div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Date retour prévue</label>
                            {{ form_widget(form.dateRetourPrevue, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.dateRetourPrevue) }}
                        </div>
                        <div class="form-check mb-3">
                            {{ form_widget(form.prolonge, {'attr': {'class': 'form-check-input'}}) }}
                            <label class="form-check-label" for="{{ form.prolonge.vars.id }}">Prolongé ?</label>
                            {{ form_errors(form.prolonge) }}
                        </div>
                        <div class="d-flex justify-content-between">
                            <a class="btn btn-outline-secondary" href="{{ path('admin_emprunts') }}">Annuler</a>
                            <button class="btn btn-primary" type="submit">Enregistrer</button>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        const initEmpruntLookup = () => {
            const input = document.querySelector('[name="emprunt[codeBarres]"]');
            const preview = document.getElementById('doc-preview');
            const dateRetour = document.querySelector('[name="emprunt[dateRetourPrevue]"]');

            if (input && preview) {
                const lookup = (code) => {
                    if (!code || code.length < 2) {
                        preview.textContent = '';
                        preview.className = 'small mt-2 text-muted';
                        return;
                    }
                    fetch(`{{ path('admin_documents_lookup') }}?code=${encodeURIComponent(code)}`)
                        .then(r => r.json())
                        .then(data => {
                            if (!data.found) {
                                preview.textContent = 'Aucun document pour ce code-barres';
                                preview.className = 'small mt-2 text-danger';
                            } else {
                                preview.textContent = `${data.titre} — ${data.disponible ? 'Disponible' : 'Déjà emprunté'}`;
                                preview.className = 'small mt-2 ' + (data.disponible ? 'text-success' : 'text-warning');
                            }
                        })
                        .catch(() => {
                            preview.textContent = 'Erreur de recherche';
                            preview.className = 'small mt-2 text-danger';
                        });
                };
                input.addEventListener('input', (e) => lookup(e.target.value.trim()));
                // Au chargement, si un code est déjà présent (copié/collé), on l'affiche
                if (input.value) {
                    lookup(input.value.trim());
                }
            }
            // Limite retour max 3 mois
            if (dateRetour) {
                const today = new Date();
                const max = new Date();
                max.setMonth(max.getMonth() + 3);
                const toISO = (d) => d.toISOString().slice(0,10);
                dateRetour.setAttribute('min', toISO(today));
                dateRetour.setAttribute('max', toISO(max));
                const msg = document.createElement('div');
                msg.className = 'small mt-1 text-muted';
                dateRetour.parentNode.appendChild(msg);
                // Si la valeur dépasse, on la ramène
                dateRetour.addEventListener('change', (e) => {
                    const val = new Date(e.target.value);
                    if (val > max) {
                        e.target.value = toISO(max);
                        msg.textContent = 'Date ajustée : dépasse le maximum (3 mois).';
                        msg.className = 'small mt-1 text-warning';
                    } else if (val < today) {
                        e.target.value = toISO(today);
                        msg.textContent = 'Date ajustée : pas de date antérieure à aujourd’hui.';
                        msg.className = 'small mt-1 text-danger';
                    } else {
                        msg.textContent = '';
                        msg.className = 'small mt-1 text-muted';
                    }
                });
            }
        };
        document.addEventListener('DOMContentLoaded', initEmpruntLookup);
        document.addEventListener('turbo:load', initEmpruntLookup);
    </script>
{% endblock %}
