{% extends 'base.html.twig' %}

{% block title %}Vérification email{% endblock %}

{% block content %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-7">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h1 class="h4 mb-3 text-center">Vérifier votre email</h1>
                    <p class="text-muted small text-center mb-4">
                        Un code de vérification a été envoyé à votre adresse email. Saisissez-le pour activer votre compte.
                    </p>

                    {{ form_start(verificationForm) }}
                        <div class="form-floating mb-3">
                            {{ form_widget(verificationForm.code, {'attr': {'class': 'form-control', 'placeholder': 'Code de vérification'}}) }}
                            <label for="{{ verificationForm.code.vars.id }}">Code de vérification</label>
                            {{ form_errors(verificationForm.code) }}
                        </div>
                        <button class="btn btn-primary w-100" type="submit">Valider</button>
                    {{ form_end(verificationForm) }}

                    <form method="post" action="{{ path('app_verify_resend') }}" class="mt-3 text-center">
                        <button class="btn btn-link p-0" type="submit">Renvoyer le code (expire dans 15 minutes)</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
