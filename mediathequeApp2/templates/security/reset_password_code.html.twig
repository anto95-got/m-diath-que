{% extends 'base.html.twig' %}

{% block title %}Vérifier le code{% endblock %}

{% block content %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-5">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h1 class="h5 mb-3">Vérifier le code</h1>
                    <p class="text-muted small">Compte: {{ masked_email }}. Entre le code reçu par email.</p>

                    <form method="post">
                        <div class="form-floating mb-3">
                            <input type="text" class="form-control" id="code" name="code" required placeholder="Code" maxlength="6">
                            <label for="code">Code</label>
                        </div>
                        <button class="btn btn-primary w-100" type="submit">Valider le code</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

