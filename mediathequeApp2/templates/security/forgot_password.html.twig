{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié{% endblock %}

{% block content %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-5">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h1 class="h5 mb-3">Mot de passe oublié</h1>
                    <p class="text-muted small">Saisis ton email pour recevoir un code.</p>

                    <form method="post">
                        <div class="form-floating mb-3">
                            <input type="email" class="form-control" id="email" name="email" required placeholder="Email">
                            <label for="email">Email</label>
                        </div>
                        <button class="btn btn-primary w-100" type="submit">Envoyer le code</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

