{% extends 'base.html.twig' %}

{% block title %}Super Admin - Utilisateurs{% endblock %}

{% block content %}
<div class="container py-5">
    <h1 class="h4 mb-4">Super Admin - Utilisateurs</h1>
    <p class="text-muted small">Vue restreinte: uniquement identité, email, rôle, statut.</p>

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Nom</th>
                        <th>Prénom</th>
                        <th>Email</th>
                        <th>Rôle</th>
                        <th>Actif</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for u in users %}
                    <tr>
                        <td>{{ u.idUtilisateur }}</td>
                        <td>{{ u.nom }}</td>
                        <td>{{ u.prenom }}</td>
                        <td>{{ u.email }}</td>
                        <td>{{ u.idRole ? u.idRole.nomRole : '-' }}</td>
                        <td>{{ u.actif ? 'Oui' : 'Non' }}</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary" href="{{ path('super_admin_user_show', {'idUtilisateur': u.idUtilisateur}) }}">Voir</a>
                            {% if u.isAdmin and not u.isSuperAdmin %}
                                <form method="post" action="{{ path('super_admin_revoke_admin', {'idUtilisateur': u.idUtilisateur}) }}" class="d-inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('revoke_admin' ~ u.idUtilisateur) }}">
                                    <button class="btn btn-sm btn-outline-danger" type="submit">Révoquer admin</button>
                                </form>
                            {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="7" class="text-center text-muted py-4">Aucun utilisateur</td></tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}

